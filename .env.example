# Copy this file to .env and fill in your values

# Groq API key — required for PoofieAI chatbot
# Get yours at: https://console.groq.com
EXPO_PUBLIC_GROQ_KEY=your_groq_api_key_here

# Backend URL — optional, defaults to the Railway production URL
# Set this to http://<your-local-ip>:5000 for local development
# EXPO_PUBLIC_BACKEND_URL=http://10.0.0.1:5000
