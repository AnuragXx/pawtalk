# Copy this file to .env and fill in your values

# Flask settings
FLASK_ENV=production
PORT=5000

# Firebase Admin SDK — required for Firestore admin routes (/checklist, /registerPushToken, etc.)
# Generate from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON content as a single-line string (minified)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}
